# ── LLM ──────────────────────────────────────────────────────────────────────
# LegalRAG uses the openai Python library purely as an HTTP client.
# It speaks the OpenAI Chat Completions API spec, which is also implemented by:
#   - HuggingFace Inference Router  (default – Qwen3.5 via Novita)
#   - vLLM          (local GPU server, serves Qwen / Llama / Mistral / etc.)
#   - Ollama        (local CPU/GPU, easy setup)
#   - Alibaba DashScope (cloud, Qwen)
#   - OpenAI        (GPT-4o etc.)
#
# ── Default: Qwen3.5-397B via HuggingFace Inference Router (Novita backend) ──
#   Get your token at https://huggingface.co/settings/tokens
#   export HF_TOKEN=hf_...
LLM_BASE_URL=https://router.huggingface.co/v1
LLM_API_KEY=hf_...              # set to your HF_TOKEN value
LLM_MODEL=Qwen/Qwen3.5-397B-A17B:novita
#
# ── Alternatives ─────────────────────────────────────────────────────────────
# vLLM (local GPU):
#   LLM_BASE_URL=http://localhost:8000/v1
#   LLM_API_KEY=EMPTY
#   LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
#
# Ollama (local CPU/GPU):
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=qwen2.5:7b
#
#
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o

# ── Embeddings ────────────────────────────────────────────────────────────────
# EMBEDDING_PROVIDER options:
#   sentence_transformers  → local model via HuggingFace (default, no API key)
#   openai                 → OpenAI / compatible API embeddings
#
# Recommended local models (all run on CPU, GPU optional):
#   sentence-transformers/all-MiniLM-L6-v2  (384-dim,  22M params, very fast)
#   BAAI/bge-large-en-v1.5                  (1024-dim, best quality for English)
#   BAAI/bge-m3                             (1024-dim, multilingual – good for French QC docs)
#   intfloat/e5-large-v2                    (1024-dim, strong legal retrieval)
#
#  EMBEDDING_DIM must match the model output dimension.
#     Changing the model requires deleting and recreating the OpenSearch index:
#       curl -X DELETE http://localhost:9200/legalrag
#     then re-run ingestion.

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── OpenSearch ────────────────────────────────────────────────────────────────
# Security is disabled for local dev (see docker-compose.yml).
# Ports are bound to 127.0.0.1 so not reachable from the network.
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin123!
OPENSEARCH_USE_SSL=false
OPENSEARCH_INDEX_NAME=legalrag

# ── Reranker ──────────────────────────────────────────────────────────────────
# Cross-encoder reranker (runs locally, no API key needed)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=80
RERANK_TOP_K=20
CHUNK_SIZE=512
CHUNK_OVERLAP=64
